<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Микро-трекер · Три дела</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        }
        body {
            background: linear-gradient(145deg, #f0f4fa 0%, #d9e2ef 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 16px;
        }
        .card {
            max-width: 520px;
            width: 100%;
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: 48px;
            padding: 28px 24px 36px;
            box-shadow: 0 30px 50px rgba(0, 10, 30, 0.2),
                        inset 0 2px 4px rgba(255, 255, 255, 0.8);
            border: 1px solid rgba(255,255,255,0.6);
            transition: all 0.2s ease;
        }
        h1 {
            font-size: 2.2rem;
            font-weight: 600;
            letter-spacing: -0.5px;
            color: #1a2639;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 6px;
            padding-left: 8px;
        }
        h1 span {
            background: #2d3b5a;
            color: white;
            font-size: 1rem;
            padding: 6px 14px;
            border-radius: 60px;
            font-weight: 400;
            letter-spacing: 0.3px;
            background: #334155;
        }
        .sub {
            color: #2d4059;
            margin-bottom: 28px;
            font-size: 1rem;
            padding-left: 12px;
            border-left: 4px solid #5f7f9e;
            font-weight: 400;
            opacity: 0.9;
        }
        /* блок ввода */
        .add-task {
            display: flex;
            gap: 10px;
            margin-bottom: 32px;
            flex-wrap: wrap;
        }
        .add-task input {
            flex: 1 1 200px;
            padding: 18px 20px;
            border: none;
            border-radius: 40px;
            background: rgba(255,255,255,0.7);
            backdrop-filter: blur(4px);
            box-shadow: inset 0 5px 8px rgba(0,0,0,0.05), 0 2px 4px rgba(255,255,255,0.7);
            font-size: 1.1rem;
            outline: none;
            transition: 0.15s;
            color: #1e2b3a;
        }
        .add-task input:focus {
            background: white;
            box-shadow: inset 0 4px 7px rgba(0,0,0,0.02), 0 0 0 3px rgba(105, 130, 160, 0.3);
        }
        .add-task input::placeholder {
            color: #677f98;
            font-weight: 300;
            font-size: 1rem;
        }
        .add-task button {
            background: #33485d;
            border: none;
            padding: 0 28px;
            border-radius: 60px;
            font-weight: 600;
            font-size: 1.2rem;
            color: white;
            letter-spacing: 0.4px;
            cursor: pointer;
            box-shadow: 0 10px 15px -7px #1f2e3c, 0 0 0 1px rgba(255,255,255,0.3) inset;
            transition: all 0.12s;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(255,255,255,0.2);
        }
        .add-task button:hover {
            background: #3e5670;
            transform: scale(1.02);
            box-shadow: 0 16px 20px -10px #1f2e3c;
        }
        .add-task button:active {
            transform: scale(0.98);
            background: #293c4f;
        }

        /* список дел */
        .tasks-header {
            display: flex;
            justify-content: space-between;
            padding: 0 10px 12px 10px;
            font-weight: 500;
            color: #344e6c;
            border-bottom: 2px dashed #b3c7db;
            margin-bottom: 16px;
        }
        .task-list {
            list-style: none;
            padding: 0;
            margin: 0 0 20px 0;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .task-item {
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(4px);
            border-radius: 100px;
            padding: 4px 4px 4px 18px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border: 1px solid rgba(255,255,255,0.8);
            box-shadow: 0 8px 14px -10px #7f8f9f;
            transition: all 0.2s;
        }
        .task-item:hover {
            background: rgba(255, 255, 255, 0.8);
            border-color: white;
            box-shadow: 0 10px 18px -8px #3f5568;
        }
        .task-left {
            display: flex;
            align-items: center;
            gap: 14px;
            flex: 1;
            cursor: pointer;
            padding: 8px 0;
        }
        .task-check {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: white;
            border: 2px solid #426080;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 18px;
            font-weight: 600;
            transition: 0.1s;
            box-shadow: 0 3px 5px rgba(0,0,0,0.1);
            flex-shrink: 0;
        }
        .task-check.completed {
            background: #2d5e3b;
            border-color: #1f4729;
            color: white;
        }
        .task-text {
            font-size: 1.2rem;
            font-weight: 500;
            color: #1f2e41;
            word-break: break-word;
            padding-right: 8px;
        }
        .task-text.line-through {
            text-decoration: line-through;
            color: #5f728b;
            font-weight: 400;
        }
        .delete-btn {
            background: rgba(230, 100, 100, 0.1);
            border: none;
            width: 46px;
            height: 46px;
            border-radius: 50%;
            font-size: 1.6rem;
            font-weight: 400;
            color: #8f4e4e;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.12s;
            backdrop-filter: blur(2px);
            border: 1px solid rgba(200,120,120,0.3);
            line-height: 1;
            margin-right: 2px;
        }
        .delete-btn:hover {
            background: #d65f5f;
            color: white;
            border-color: #b24949;
            transform: scale(1.1);
        }
        .delete-btn:active {
            background: #a54242;
            transform: scale(0.95);
        }
        /* статистика */
        .stats {
            background: rgba(210, 225, 240, 0.6);
            backdrop-filter: blur(8px);
            border-radius: 80px;
            padding: 16px 22px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            border: 1px solid white;
            font-weight: 500;
            color: #1e3b4f;
            box-shadow: inset 0 2px 6px white, 0 10px 18px -16px #1f3442;
        }
        .progress {
            background: #51718c;
            color: white;
            padding: 8px 22px;
            border-radius: 60px;
            font-size: 1.1rem;
            letter-spacing: 0.5px;
            box-shadow: inset 0 -3px 0 #2f4357;
        }
        .reset-btn {
            background: rgba(60, 80, 100, 0.25);
            border: 1px solid rgba(255,255,255,0.8);
            font-size: 1rem;
            padding: 10px 20px;
            border-radius: 50px;
            font-weight: 500;
            color: #2c4055;
            cursor: pointer;
            transition: 0.1s;
            backdrop-filter: blur(4px);
        }
        .reset-btn:hover {
            background: #ffffff90;
            border-color: #667e99;
            color: #0e263b;
        }
        .empty-message {
            text-align: center;
            color: #5a738e;
            font-style: italic;
            padding: 30px 10px;
            background: rgba(255,255,255,0.3);
            border-radius: 80px;
            font-size: 1.1rem;
            backdrop-filter: blur(4px);
        }
        footer {
            font-size: 0.8rem;
            text-align: center;
            margin-top: 24px;
            color: #576f86;
            opacity: 0.8;
        }
    </style>
</head>
<body>
<div class="card">
    <h1>🧩 три дела <span>микро</span></h1>
    <div class="sub">фокус на главном · отмечай выполненное</div>

    <!-- Поле ввода + кнопка -->
    <div class="add-task">
        <input type="text" id="taskInput" placeholder="например, зарядка" maxlength="42" autofocus>
        <button id="addBtn">➕</button>
    </div>

    <!-- шапка списка -->
    <div class="tasks-header">
        <span>📋 мои задачи</span>
        <span id="counter">0 / 0</span>
    </div>

    <!-- Контейнер для списка -->
    <ul class="task-list" id="taskListContainer">
        <!-- задачи будут рендериться здесь -->
    </ul>

    <!-- Статистика и сброс -->
    <div class="stats">
        <span class="progress" id="progressPercent">0%</span>
        <button class="reset-btn" id="resetCompletedBtn">✔️ очистить сделанное</button>
    </div>
    <footer>︎︎︎︎клик по задаче — переключить · крестик — удалить</footer>
</div>

<script>
    (function() {
        // ---- основные данные ----
        let tasks = [];

        // грузим из localStorage
        const STORAGE_KEY = 'micro_tasks_app';
        try {
            const saved = localStorage.getItem(STORAGE_KEY);
            if (saved) {
                tasks = JSON.parse(saved);
                // небольшая валидация на всякий случай
                if (!Array.isArray(tasks)) tasks = [];
            }
        } catch (e) {
            console.warn('Не удалось загрузить сохранения');
            tasks = [];
        }

        // ---- DOM элементы ----
        const taskInput = document.getElementById('taskInput');
        const addBtn = document.getElementById('addBtn');
        const taskListContainer = document.getElementById('taskListContainer');
        const counterSpan = document.getElementById('counter');
        const progressPercent = document.getElementById('progressPercent');
        const resetBtn = document.getElementById('resetCompletedBtn');

        // ---- вспомогательные функции ----
        function saveToStorage() {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(tasks));
        }

        // обновление счётчиков и прогресса
        function updateStats() {
            const total = tasks.length;
            const completedCount = tasks.filter(t => t.completed).length;
            counterSpan.innerText = `${completedCount} / ${total}`;

            const percent = total === 0 ? 0 : Math.round((completedCount / total) * 100);
            progressPercent.innerText = percent + '%';
        }

        // отрисовка списка (полная перерисовка, но tasks маленькие — ок)
        function renderTasks() {
            if (tasks.length === 0) {
                taskListContainer.innerHTML = `<li class="empty-message">✌️ Добавь первую задачу</li>`;
                updateStats();
                return;
            }

            let html = '';
            for (let i = 0; i < tasks.length; i++) {
                const task = tasks[i];
                const checkedClass = task.completed ? 'completed' : '';
                const textDecor = task.completed ? 'line-through' : '';

                // Важно: используем data-index для идентификации
                html += `
                    <li class="task-item" data-index="${i}">
                        <div class="task-left" data-index="${i}">
                            <span class="task-check ${checkedClass}" data-index="${i}">${task.completed ? '✓' : ''}</span>
                            <span class="task-text ${textDecor}" data-index="${i}">${escapeHtml(task.text) || '—'}</span>
                        </div>
                        <button class="delete-btn" data-index="${i}" aria-label="Удалить">✕</button>
                    </li>
                `;
            }
            taskListContainer.innerHTML = html;
            updateStats();
        }

        // простая защита от XSS
        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return unsafe
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // добавление новой задачи
        function addNewTask() {
            const text = taskInput.value.trim();
            if (text === '') {
                // легкая встряска для пустого поля
                taskInput.style.transition = '0.1s';
                taskInput.style.transform = 'scale(1.02)';
                setTimeout(() => taskInput.style.transform = '', 120);
                return;
            }
            // добавляем
            tasks.push({
                text: text,
                completed: false
            });
            saveToStorage();
            renderTasks();
            taskInput.value = '';
            taskInput.focus();
        }

        // переключение состояния (complete / incomplete)
        function toggleTask(index) {
            if (index >= 0 && index < tasks.length) {
                tasks[index].completed = !tasks[index].completed;
                saveToStorage();
                renderTasks();
            }
        }

        // удаление задачи
        function deleteTask(index) {
            if (index >= 0 && index < tasks.length) {
                tasks.splice(index, 1);
                saveToStorage();
                renderTasks();
            }
        }

        // удалить все выполненные
        function removeCompleted() {
            tasks = tasks.filter(t => !t.completed);
            saveToStorage();
            renderTasks();
        }

        // обработчик кликов на список (делегирование)
        function handleListClick(e) {
            const target = e.target;
            const li = target.closest('.task-item');
            if (!li) return;

            const index = li.dataset.index; // строка

            if (index === undefined) return;

            const idx = parseInt(index, 10);
            if (isNaN(idx) || idx < 0 || idx >= tasks.length) return;

            // 1. клик на delete-btn (крестик)
            if (target.classList.contains('delete-btn') || target.closest('.delete-btn')) {
                e.preventDefault();
                deleteTask(idx);
                return;
            }

            // 2. клик на область задачи (любой элемент с data-index внутри левой части) 
            // но только если это не кнопка удаления (уже обработано)
            if (target.closest('.task-left') || target.classList.contains('task-item')) {
                toggleTask(idx);
            }
        }

        // нажатие Enter в поле
        function onInputKeyPress(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                addNewTask();
            }
        }

        // ---- установка слушателей ----
        addBtn.addEventListener('click', (e) => {
            e.preventDefault();
            addNewTask();
        });

        taskListContainer.addEventListener('click', handleListClick);

        taskInput.addEventListener('keypress', onInputKeyPress);

        resetBtn.addEventListener('click', (e) => {
            e.preventDefault();
            removeCompleted();
        });

        // дополнительно: сброс подсветки при фокусе
        taskInput.addEventListener('animationend', () => {
            taskInput.style.transform = '';
        });

        // ---- инициализация (первый рендер) ----
        renderTasks();
    })();
</script>
</body>
</html>